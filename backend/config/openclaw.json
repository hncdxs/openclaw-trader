{
  "agent": {
    "model": "minimax/m2.7",
    "thinking": "high"
  },
  "gateway": {
    "port": 18789,
    "verbose": true
  },
  "providers": {
    "minimax": {
      "base_url": "https://api.minimaxi.com/v1",
      "api_key": "${MINIMAX_API_KEY}"
    }
  },
  "mcp_servers": {
    "okx": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@okx/ai-trade-kit@latest",
        "mcp",
        "--api-key", "${OKX_API_KEY}",
        "--secret-key", "${OKX_SECRET_KEY}",
        "--passphrase", "${OKX_PASSPHRASE}"
      ]
    }
  },
  "tools": {
    "allow": ["*"]
  },
  "agents": {
    "defaults": {
      "workspace": "/root/.openclaw/workspace"
    }
  }
}
